<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane id="AnchorPane" prefHeight="519.0" prefWidth="581.0" styleClass="mainFxmlClass" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.cardpro4.controller.CadastroCartaController">
    <stylesheets>
        <URL value="@/styles/cadastrocarta.css" />
    </stylesheets>
   <children>
      <TextField fx:id="nomeField" layoutX="45.0" layoutY="205.0" prefHeight="26.0" prefWidth="254.0" promptText="Nome" />
      <ComboBox fx:id="raridadeBox" layoutX="45.0" layoutY="255.0" prefWidth="150.0" promptText="Raridade" />
      <ComboBox fx:id="temaBox" layoutX="45.0" layoutY="302.0" prefWidth="150.0" promptText="Tema" />
      <ComboBox fx:id="colecaoBox" layoutX="44.0" layoutY="346.0" prefWidth="150.0" promptText="Collection" />
      <Button fx:id="addCollectionButton" layoutX="214.0" layoutY="346.0" mnemonicParsing="false" onAction="#goToCadastroBinder" prefHeight="26.0" prefWidth="94.0" text="Add Collection" />
      <Button fx:id="btnBack" layoutX="14.0" layoutY="14.0" mnemonicParsing="false" onAction="#goToCollection" prefHeight="26.0" prefWidth="30.0" text="&lt;" />
      <Button fx:id="addButton" layoutX="431.0" layoutY="428.0" mnemonicParsing="false" onAction="#cadastrarCarta" prefHeight="40.0" prefWidth="94.0" text="Add" />
      
      <!-- Seção para adicionar e exibir a imagem -->
      <Button fx:id="selectImageButton" layoutX="376.0" layoutY="346.0" mnemonicParsing="false" prefHeight="26.0" prefWidth="150.0" text="Selecionar Imagem" />
      <ImageView fx:id="imagePreview" fitHeight="129.0" fitWidth="150.0" layoutX="349.0" layoutY="88.0" preserveRatio="true" />
      <ImageView fitHeight="284.0" fitWidth="195.0" layoutX="354.0" layoutY="52.0" pickOnBounds="true" preserveRatio="true" />
   </children>
</AnchorPane>
